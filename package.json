{
  "name": "gitbanshee",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:ui": "npm --prefix ui run dev",
    "build": "npm --prefix ui run build",
    "preview": "npm --prefix ui run preview",
    "tauri:dev": "tauri dev --config engine/tauri.conf.json",
    "tauri:build": "tauri build --config engine/tauri.conf.json",
    "check:rs": "cargo check --manifest-path engine/Cargo.toml",
    "check:ts": "npm --prefix ui run build",
    "check": "npm run check:ts && npm run check:rs"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4"
  }
}
